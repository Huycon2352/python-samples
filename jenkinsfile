pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Huycon2352/python-samples.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t myapp .'
            }
        }
        stage('Debug Workspace') {
    steps {
        sh 'echo "Current dir:"'
        sh 'pwd'
        sh 'echo "Files in workspace:"'
        sh 'ls -la'
        sh 'echo "Find Dockerfile:"'
        sh 'find . -name Dockerfile'
    }
}

    }

}
